prefer-no-csd
screenshot-path "~/Pictures/Screenshots/ss-%Y-%m-%d-%H-%M-%S.png"
config-notification {
    disable-failed
}
gestures {
    hot-corners {
        off
    }
}
environment {
    XDG_CURRENT_DESKTOP niri
    QT_QPA_PLATFORMTHEME qt6ct
}
hotkey-overlay {
    skip-at-startup
}
debug {
    honor-xdg-activation-with-invalid-serial
}
overview {
    workspace-shadow {
        off
    }
}

