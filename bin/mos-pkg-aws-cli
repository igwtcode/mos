#!/usr/bin/env bash

dir=$(mktemp -d)
trap 'rm -rf "$dir"' EXIT

(
  cd "$dir" || exit 1
  filename="awscli-exe-linux-x86_64.zip"
  url="https://awscli.amazonaws.com/$filename"
  curl -sS "$url" -o "$filename"
  unzip -q "$filename"
  sudo ./aws/install \
    --bin-dir /usr/local/bin \
    --install-dir /usr/local/aws-cli \
    --update
)
